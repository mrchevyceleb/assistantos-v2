{
  "name": "assistantos",
  "version": "1.0.0",
  "type": "module",
  "description": "Your personal AI assistant operating system",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.node.json && tsc -p tsconfig.preload.json && cross-env NODE_ENV=development electron .",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.preload.json && vite build",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [
    "assistant",
    "ai",
    "claude",
    "electron",
    "productivity"
  ],
  "author": "Matt Johnston",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@milkdown/kit": "^7.18.0",
    "@milkdown/theme-nord": "^7.18.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tailwindcss/typography": "^0.5.19",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.562.0",
    "openai": "^6.16.0",
    "path-browserify": "^1.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.2.2",
    "zustand": "^5.0.9"
  },
  "build": {
    "appId": "io.assistantos.app",
    "productName": "AssistantOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
