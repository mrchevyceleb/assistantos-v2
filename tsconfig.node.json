{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "dist-electron",
    "target": "ES2020",
    "lib": ["ES2020"]
  },
  "include": ["electron/main.ts", "electron/mcp/**/*.ts", "vite.config.ts"],
  "exclude": ["electron/preload.ts"]
}
