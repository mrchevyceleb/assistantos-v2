# Supabase Configuration
# Required for persistent memory system
MEMORY_SUPABASE_URL=your_supabase_url_here
MEMORY_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: OpenAI API Key for embeddings (used in memory system)
# If not provided, memory system will use keyword search instead of semantic search
OPENAI_API_KEY=your_openai_key_here
