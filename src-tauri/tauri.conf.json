{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AssistantOS",
  "version": "1.0.2",
  "identifier": "com.mtjoh.assistantos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "AssistantOS",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://github.com https://api.github.com; frame-src 'self' asset: https://asset.localhost blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mrchevyceleb/assistantos-v2-updates/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDMjZCNEY2NTg4MTNFMTIKUldRU1BvRlk5clFtckQyMVFwR0t6UXFwVkZrRU9BaWgrZ0h4bFpJeWYrQUpKcElkc3QxWjB3UjMK"
    }
  }
}
